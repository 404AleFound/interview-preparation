        }
      ],
      "updated": 1775372030947,
      "link": null,
      "locked": false,
      "text": "条件一：要等到窗口大小 >= MSS 并且 数据大小 >= MSS；\n条件二：收到之前发送数据的 ack 回包；",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "条件一：要等到窗口大小 >= MSS 并且 数据大小 >= MSS；\n条件二：收到之前发送数据的 ack 回包；",
      "autoResize": true,
      "lineHeight": 1.25
    },
