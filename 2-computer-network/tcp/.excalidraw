      "boundElements": [],
      "updated": 1775322074373,
      "link": null,
      "locked": false,
      "text": "当没有响应数据要发送时，ACK 将会延迟一段时间，以等待是否有响应数据可以一起发送",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "Lp5cU44RmgrfomJ15i_To",
      "originalText": "当没有响应数据要发送时，ACK 将会延迟一段时间，以等待是否有响应数据可以一起发送",
      "autoResize": true,
      "lineHeight": 1.25
    },
